# 在 services/api 目录下复制为 .env 后按需覆盖。
# 学生密码可逆加密（AES-GCM）的 32 字节密钥，base64。脚手架默认值仅用于本机；生产必换。
# STUDENT_PASSWORD_KEY=

# DATABASE_URL=sqlite+aiosqlite:///./data/teach.db
# JWT_SECRET=change-me-in-prod
# 生产环境 HTTPS 下建议为 true，使 `teacher_session` 带 `Secure`。
# ADMIN_COOKIE_SECURE=false
# 若设置，则首次 POST /v1/admin/bootstrap 需同时带请求头 X-Admin-Bootstrap-Token: <同值>
# ADMIN_BOOTSTRAP_TOKEN=
# 学生 JWT 有效分钟数（默认 15）
# STUDENT_JWT_EXP_MINUTES=15
# 章生成：1/yes = 固定 JSON；0 时用 httpx 调真 LLM（须 LLM_BASE_URL）
# CHAPTER_GEN_MOCK=1
# OpenAI 兼容 LLM。多数厂商基址不要带路径 /v1（代码会拼 /v1/chat/completions）。
# 若写成 https://openrouter.ai/api/v1 或 https://api.siliconflow.cn/v1，运行时会自动去掉尾部 /v1。
# DeepSeek 官方路径为 https://api.deepseek.com/chat/completions，代码会按基址自动适配。
# OpenRouter 示例：LLM_BASE_URL=https://openrouter.ai/api
# 硅基流动示例：LLM_BASE_URL=https://api.siliconflow.cn
# DeepSeek 示例：LLM_BASE_URL=https://api.deepseek.com
# LLM_BASE_URL=
# LLM_API_KEY=
# 模型名以厂商为准，如 openai/gpt-4o-mini、Qwen/Qwen2.5-7B-Instruct
# CHAPTER_GEN_MODEL=gpt-4o-mini
# 学生聊天代理（设计 §7）；可与章生成用同一厂商；不配 CHAT_* 时回退到 LLM_BASE_URL / LLM_API_KEY
# CHAT_LLM_BASE_URL=
# CHAT_LLM_API_KEY=
# 硅基流动示例：
# CHAT_LLM_BASE_URL=https://api.siliconflow.cn
# CHAT_LLM_API_KEY=你的硅基流动 API Key
# CHAT_MODEL=deepseek-ai/DeepSeek-V4-Flash
# DeepSeek 示例：
# CHAT_LLM_BASE_URL=https://api.deepseek.com
# CHAT_LLM_API_KEY=你的 DeepSeek API Key
# CHAT_MODEL=deepseek-v4-flash
# OpenRouter 可选：请求来源与标题（见 openrouter.ai 文档）
# OPENROUTER_HTTP_REFERER=
# OPENROUTER_TITLE=
# CHAT_CONTEXT_MAX_CHARS=12000
# CHAT_RPM=20
# CHAT_DAILY_TOKEN_BUDGET=0
# 学生「AI学习助手」专用模型（不配则与章生成共用 CHAPTER_GEN_MODEL / LLM_*）
# OpenRouter 免费代码向示例：CHAT_MODEL=qwen/qwen3-coder:free
# CHAT_MODEL=gpt-4o-mini
# （可与 CHAPTER_GEN_MODEL 相同或选更小/更快模型）
# 教师 Web：浏览器访问 http://127.0.0.1:8000/teacher（与 API 同域）
# 学生端 CORS：默认 `CORS_DEV_LOCALHOST_REGEX=true` 时允许 http(s)://localhost、127.0.0.1、tauri.localhost 任意端口，避免 Vite 换端口导致 Chat「Failed to fetch」。生产可设 `CORS_DEV_LOCALHOST_REGEX=false` 并只保留显式 `allow_origins`。
# CORS_DEV_LOCALHOST_REGEX=true
# 教师名单页：在默认隐藏的演示学号 bujiuhong6 之外追加不展示的学号（逗号分隔）；仅隐藏展示，不删库；删除与批量接口也会忽略。
# TEACHER_ROSTER_HIDDEN_STUDENT_NOS=

# -----------------------------------------------------------------------------
# 生产部署建议（同源 HTTPS，例如 nginx 反向代理 teacher/API + /student SPA）
# -----------------------------------------------------------------------------
# 已由 TLS 终结时：`teacher_session` 应带 Secure。复制到服务器 `.env` 后启用：
# ADMIN_COOKIE_SECURE=true
# 生产关闭「任意 localhost 端口」CORS；同域部署由 Nginx 提供同源入口。复制到服务器 `.env` 后启用：
# CORS_DEV_LOCALHOST_REGEX=false
# JWT_SECRET：服务端签发教师会话等签名用，须为足够长的随机密钥（示例：`openssl rand -hex 32`）。仅写入服务器上 `.env`，勿入库、勿提交。
# JWT_SECRET=
# STUDENT_PASSWORD_KEY：AES-GCM 用 32 字节密钥，Base64（示例：`openssl rand -base64 32`）。
# 迁移既有 SQLite 时必须与原库保持一致；原本为空或注释时，服务器也保持为空或注释。
# STUDENT_PASSWORD_KEY=
